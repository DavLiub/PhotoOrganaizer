# Copy this file to android/key.properties for local release signing.
# Never commit android/key.properties or keystore files.
#
# storeFile is resolved from android/app/build.gradle.kts.
# Use a local file path or an absolute path that is not committed.
storeFile=upload-keystore.jks
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=upload
keyPassword=REPLACE_WITH_KEY_PASSWORD
